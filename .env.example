# 内置线路（默认线路）的服务端配置。
# 这些变量仅由服务端的 /api/analyze 读取，不加 VITE_ 前缀，
# 因此不会被打包进客户端，浏览器无法读到。
#
# 本地开发：复制本文件为 .env.local 并填入真实值。
# 线上部署：在 Vercel → Settings → Environment Variables 中配置同名变量。

BUILTIN_API_KEY=
BUILTIN_BASE_URL=https://api.qnaigc.com/v1
BUILTIN_MODEL=deepseek/deepseek-v3.2-251201

# ── 开放端点防滥用（可选，仅生产 /api/analyze 生效）──
# 按 IP 限流，防止有人刷爆内置 Key 的额度。在 Upstash 免费创建一个
# Redis 后填入下面两个值；不配置则不限流（自定义线路不受影响）。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 每个 IP 在 10 分钟内允许的请求数，默认 30。按需调整。
RATELIMIT_REQUESTS=30

# 额外允许的来源（逗号分隔）。同源请求始终放行，通常留空；
# 仅当你把前端部署到另一个域名时才需要填。
ALLOWED_ORIGINS=
